# ── InsightLens web server configuration ──────────────────────────────────
# Copy to .env and fill in. In Docker, pass these via docker-compose `env_file:`
# or `-e` flags — the server reads process.env, never a file directly.

# Which LLM provider to use. One of:
#   openai | anthropic | gemini | groq | openrouter | ollama | custom
AI_PROVIDER=openai

# Model name for the chosen provider, e.g. gpt-4o-mini, claude-3-5-sonnet,
# gemini-1.5-flash, llama-3.1-8b-instant (groq), etc.
AI_MODEL=gpt-4o-mini

# API key. Either set this generic key, OR the provider-specific variable below
# (the provider variable is used as a fallback).
AI_API_KEY=

# Provider-specific key variables (used if AI_API_KEY is empty):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=     (or GEMINI_API_KEY=)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Base URL override. Required for 'custom' and 'ollama'; optional otherwise.
# Examples: http://localhost:11434/v1 (Ollama), https://your-host/v1
# AI_BASE_URL=

# Port the server listens on (container port).
PORT=8080
