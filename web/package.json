{
  "name": "insightlens-web",
  "version": "1.9.3",
  "private": true,
  "description": "InsightLens landing page, try-before-you-install web tool, and AI server",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b && tsc -p tsconfig.server.json --noEmit",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "pdfjs-dist": "^5.2.133",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
