{
  "name": "insightlens",
  "version": "1.9.1",
  "description": "Unit survey analysis tool for lecturers",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently -k \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -b -w src/main",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron . --no-sandbox",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -b src/main",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "dist": "electron-builder",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "electron",
    "survey",
    "analysis",
    "education"
  ],
  "author": "InsightLens Contributors",
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "@types/node-fetch": "^2.6.12",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.2.0",
    "electron-builder": "26.8.1",
    "postcss": "^8.4.32",
    "typescript": "^5.3.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.1",
    "chart.js": "^4.4.1",
    "d3": "^7.8.5",
    "d3-cloud": "^1.2.7",
    "date-fns": "^3.0.6",
    "electron-log": "^5.4.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.303.0",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.2.133",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-router-dom": "^6.21.1",
    "react-toastify": "^10.0.3",
    "recharts": "^2.10.3",
    "tailwindcss": "^3.4.0",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.insightlens.app",
    "productName": "InsightLens",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "afterSign": "scripts/notarize.js",
    "publish": {
      "provider": "github",
      "owner": "michael-borck",
      "repo": "insight-lens"
    },
    "mac": {
      "category": "public.app-category.education",
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "mas": {
      "category": "public.app-category.education",
      "hardenedRuntime": false,
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "signtoolOptions": {
        "publisherName": "InsightLens Contributors"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Education",
      "maintainer": "InsightLens Contributors",
      "desktop": {
        "entry": {
          "StartupNotify": "true",
          "Encoding": "UTF-8",
          "MimeType": "application/pdf"
        }
      }
    }
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
